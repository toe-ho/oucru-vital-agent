<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Quality Assessment Report</title>
<style>
  body { font-family: Arial, sans-serif; font-size: 12px; color: #1a1a1a; margin: 40px; }
  h1 { font-size: 20px; color: #1e3a5f; border-bottom: 2px solid #1e3a5f; padding-bottom: 8px; }
  h2 { font-size: 15px; color: #1e3a5f; margin-top: 24px; }
  table { border-collapse: collapse; width: 100%; margin: 12px 0; }
  th { background: #1e3a5f; color: white; padding: 6px 10px; text-align: left; }
  td { border: 1px solid #ddd; padding: 6px 10px; }
  tr:nth-child(even) { background: #f5f7fa; }
  .accept { color: #15803d; font-weight: bold; }
  .reject { color: #dc2626; font-weight: bold; }
  .verdict-acceptable { color: #15803d; }
  .verdict-marginal { color: #d97706; }
  .verdict-poor { color: #dc2626; }
  .kpi { display: inline-block; background: #f5f7fa; border: 1px solid #ddd;
         border-radius: 4px; padding: 10px 20px; margin: 4px 8px 4px 0; text-align: center; }
  .kpi-value { font-size: 22px; font-weight: bold; color: #1e3a5f; }
  .kpi-label { font-size: 10px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; }
  .note { background: #fef9c3; border-left: 4px solid #d97706; padding: 8px 12px; margin: 12px 0; }
</style>
</head>
<body>
<h1>OUCRU Vital Agent — Quality Assessment Report</h1>

<h2>Recording Summary</h2>
<div>
  <div class="kpi">
    <div class="kpi-value">{{ summary.total_segments }}</div>
    <div class="kpi-label">Total Segments</div>
  </div>
  <div class="kpi">
    <div class="kpi-value accept">{{ summary.accepted }}</div>
    <div class="kpi-label">Accepted</div>
  </div>
  <div class="kpi">
    <div class="kpi-value reject">{{ summary.rejected }}</div>
    <div class="kpi-label">Rejected</div>
  </div>
  <div class="kpi">
    <div class="kpi-value">{{ (summary.acceptance_rate * 100) | round(1) }}%</div>
    <div class="kpi-label">Acceptance Rate</div>
  </div>
  <div class="kpi">
    <div class="kpi-value verdict-{{ summary.overall_verdict }}">{{ summary.overall_verdict | upper }}</div>
    <div class="kpi-label">Overall Verdict</div>
  </div>
</div>

<table>
  <tr><th>Field</th><th>Value</th></tr>
  <tr><td>Recording ID</td><td>{{ summary.recording_id }}</td></tr>
  <tr><td>Filename</td><td>{{ summary.filename }}</td></tr>
  <tr><td>Signal Type</td><td>{{ summary.signal_type | upper }}</td></tr>
  <tr><td>Assessed At</td><td>{{ summary.assessed_at }}</td></tr>
  <tr><td>Confidence</td><td>{{ confidence | upper }}</td></tr>
</table>

{% if agent_interpretation %}
<h2>Agent Interpretation</h2>
<p>{{ agent_interpretation }}</p>
{% endif %}

{% if limitations %}
<div class="note">
  <strong>Limitations:</strong>
  <ul>{% for l in limitations %}<li>{{ l }}</li>{% endfor %}</ul>
</div>
{% endif %}

{% if flagged_segments %}
<h2>Flagged Segments ({{ flagged_segments | length }})</h2>
<table>
  <tr><th>#</th><th>Time</th><th>Quality Score</th><th>Failed Rules</th></tr>
  {% for seg in flagged_segments %}
  <tr>
    <td>{{ seg.segment_number }}</td>
    <td>{{ seg.start_time }}s – {{ seg.end_time }}s</td>
    <td class="reject">{{ seg.quality_score }}</td>
    <td>{% for r in seg.failed_rules %}{{ r.metric }} ({{ r.operator }}={{ r.threshold }}){% if not loop.last %}, {% endif %}{% endfor %}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

{% if timeline %}
<h2>Segment Timeline</h2>
<table>
  <tr><th>#</th><th>Start (s)</th><th>End (s)</th><th>Classification</th><th>Quality Score</th></tr>
  {% for seg in timeline %}
  <tr>
    <td>{{ seg.segment_number }}</td>
    <td>{{ seg.start_time }}</td>
    <td>{{ seg.end_time }}</td>
    <td class="{{ seg.classification }}">{{ seg.classification | upper }}</td>
    <td>{{ seg.quality_score }}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

<p style="margin-top:40px; color:#999; font-size:10px;">
  Generated by OUCRU Vital Agent &mdash; Oxford University Clinical Research Unit
</p>
</body>
</html>
